# Caddy with the Route53 DNS plugin, so it can solve the DNS-01 ACME challenge
# for the *.mcp.nickawilliams.com wildcard using the EC2 instance role (no
# static AWS keys on the box).
FROM caddy:2-builder AS builder
RUN xcaddy build --with github.com/caddy-dns/route53

FROM caddy:2
COPY --from=builder /usr/bin/caddy /usr/bin/caddy
